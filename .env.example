# Inch Ka — environment configuration
# Copy to .env and fill in. Never commit the real .env.

# Firecrawl (same key you connected through Composio, from firecrawl.dev)
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — Project Settings -> API. Use the SERVICE ROLE key for writes
# (server-side only; it bypasses RLS). Point this at the inch_ka project.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Optional: direct Postgres (Settings -> Database). Scraper defaults to the
# Supabase API above; set INCHKA_DB=postgres only if you need direct SQL.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# INCHKA_DB=auto

# Composio — for sending the daily digest via your connected Gmail.
COMPOSIO_API_KEY=comp_xxxxxxxxxxxxxxxxxxxx
COMPOSIO_USER_ID=default
DIGEST_TO_EMAIL=you@example.com
